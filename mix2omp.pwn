public OnFilterScriptInit()
{
    print("--------------------------------------");
    print("Mix2OMP: loading Mixed model artconfig...");

    AddMIXModels();

    print("Mix2OMP: loaded 1079 mixed model entries.");
    print("--------------------------------------");
    return 1;
}

public OnFilterScriptExit()
{
    print("Mix2OMP: filterscript unloaded.");
    return 1;
}
